{
  "description": "PHP library for generating recurring dates, schedules, and repeated task recurrences.",
  "type": "library",
  "keywords": [
    "php",
    "recurring",
    "recurrence",
    "recurrence-rule",
    "rrule",
    "schedule",
    "scheduling",
    "calendar",
    "date-generator",
    "task-scheduling",
    "repeat-events",
    "repeat-dates",
    "carbon"
  ],
  "name": "wilianx7/php-recurring",
  "homepage": "https://github.com/wilianx7/php-recurring",
  "license": "MIT",
  "authors": [
    {
      "name": "Wilian Borges",
      "email": "wilianx7@hotmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3|^8.4",
    "nesbot/carbon": "^2.73|^3.9"
  },
  "require-dev": {
    "ext-json": "*",
    "friendsofphp/php-cs-fixer": "3.75.0",
    "phpstan/phpstan": "2.1.12",
    "phpunit/phpunit": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "PhpRecurring\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpRecurring\\Tests\\": "tests"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "clear-analyse-cache": "vendor/bin/phpstan clear-result-cache",
    "lint": "php-cs-fixer fix --dry-run --diff --config .phpcs.dist",
    "fix-lint": "php-cs-fixer fix --diff --config .phpcs.dist",
    "test": "vendor/bin/phpunit",
    "test-coverage": "phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
